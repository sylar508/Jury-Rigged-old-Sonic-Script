									Thing[1].Transparency = Thing[1].Transparency + Thing[3]
								end
							else
								Part.Parent = nil
								game:GetService("Debris"):AddItem(Part, 0)
								table.remove(Effects, e)
							end
						end
					end
				end
			end

		end
