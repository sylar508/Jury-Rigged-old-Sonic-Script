		local function FindNearestTorso(Position, Distance, SinglePlayer)
			if SinglePlayer then
				return (SinglePlayer.Torso.CFrame.p - Position).magnitude < Distance
			end
			local List = {}
			for i, v in pairs(workspace:GetChildren()) do
				if v:IsA("Model") then
					local targetTorso = v:FindFirstChild("Torso") or v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("UpperTorso")
					if targetTorso and v:FindFirstChildOfClass("Humanoid") then
						if v ~= Character then
							if (targetTorso.Position - Position).magnitude <= Distance then
								table.insert(List, v)
							end 
						end 
					end 
				end 
			end
			return List
		end


		local function CreatePart(Parent, Material, Reflectance, Transparency, BColor, Name, Size)
			local Part = Instance.new("Part")
			Part.Parent = Parent
			Part.Reflectance = Reflectance
			Part.Transparency = Transparency
			Part.CanCollide = false
			Part.Locked = true
		
			if BColor == nil then
				Part.BrickColor = BrickColor.new("White") -- Default fallback if empty
			elseif typeof(BColor) == "Color3" then
				Part.Color = BColor
			elseif typeof(BColor) == "BrickColor" then
				Part.BrickColor = BColor
			else
				Part.BrickColor = BrickColor.new("White")
			end
		
			Part.Name = Name
			Part.Size = Size
			Part.Material = Material
			
			if RemoveOutlines ~= nil then
				RemoveOutlines(Part) 
			end
			
			return Part
		end

