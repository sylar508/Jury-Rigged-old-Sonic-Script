						end 
					end 
				else
					for _, v in pairs(workspace:GetChildren()) do
						if v:IsA("Model") and v ~= Character and v:FindFirstChildOfClass("Humanoid") and v:FindFirstChild("Head") then
							local targetRoot = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Torso")
							if targetRoot and (targetRoot.Position - RootPart.Position).Magnitude <= 80 then
								Grabbed = true
								homed = v
								break
							end
						end
					end
				end

