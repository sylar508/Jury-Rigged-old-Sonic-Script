		local function swait(num: number?)
			if num == 0 or num == nil then
				-- Yield exactly 1 server physics frame
				RunService.Heartbeat:Wait()
			else
				-- Perform a mathematically accurate frame countdown without over-yielding
				for _ = 1, num do
					RunService.Heartbeat:Wait()
				end
			end
		end

