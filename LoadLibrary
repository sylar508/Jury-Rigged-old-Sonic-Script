FELOADLIBRARY.SelectTerrainRegion = function(regionToSelect: Region3, color: BrickColor, selectEmptyCells: boolean, selectionParent: Instance?)
	if not Terrain then return end

	local selectionContainer = Instance.new("Model")
	selectionContainer.Name = "SelectionContainer"
	selectionContainer.Archivable = false
	selectionContainer.Parent = selectionParent or workspace

	local selectionPart = Instance.new("Part")
	selectionPart.Name = "SelectionPart"
	selectionPart.Transparency = 1
	selectionPart.Anchored = true
	selectionPart.CanCollide = false
	selectionPart.Size = regionToSelect.Size
	selectionPart.CFrame = regionToSelect.CFrame
	selectionPart.Parent = selectionContainer

	local selectionBox = Instance.new("SelectionBox")
	selectionBox.Color3 = color or BrickColor.new("Cyan")
	selectionBox.Adornee = selectionPart
	selectionBox.Parent = selectionContainer

	local updateSelection = function(newRegion: Region3, newColor: BrickColor?)
		if newRegion then
			selectionPart.Size = newRegion.Size
			selectionPart.CFrame = newRegion.CFrame
		end
		if newColor then
			selectionBox.Color3 = newColor
		end
	end

	local destroyFunc = function()
		selectionContainer:Destroy()
	end

	return updateSelection, destroyFunc
end


function FELOADLIBRARY.CreateSignal()
	local this = {}
	local bindable = Instance.new("BindableEvent")
	local connections = {}

	function this:Connect(func)
		local connection = bindable.Event:Connect(func)
		connections[connection] = true

		return {
			Disconnect = function()
				connection:Disconnect()
				connections[connection] = nil
			end
		}
	end
	this.connect = this.Connect

	function this:Wait()
		return bindable.Event:Wait()
	end
	this.wait = this.Wait

	function this:Fire(...)
		bindable:Fire(...)
	end
	this.fire = this.Fire

	function this:Disconnect()
		for cn, _ in pairs(connections) do
			cn:Disconnect()
		end
		table.clear(connections)
	end
	this.disconnect = this.Disconnect

	return this
end

local function Create_PrivImpl(objectType: string)
	return function(dat)
		dat = dat or {}
		local obj = Instance.new(objectType)
		local parent = nil

		for k, v in pairs(dat) do
			if type(k) == "string" then
				if k == "Parent" then
					parent = v
				else
					obj[k] = v
				end
			elseif type(k) == "number" and typeof(v) == "Instance" then
				v.Parent = obj
			elseif type(k) == "table" and k.__eventname then
				obj[k.__eventname]:Connect(v)
			end
		end

		if parent then
			obj.Parent = parent
		end
		return obj
	end
end

--now, create the functor:
FELOADLIBRARY.Create = setmetatable({}, {
	__call = function(tb, ...) 
		return Create_PrivImpl(...) 
	end
})

