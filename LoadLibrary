FELOADLIBRARY.DecodeJSON = function(jsonString: string)
	if type(jsonString) ~= "string" then
		warn("LoadLibrary.DecodeJSON expects a string argument!")
		return nil
	end
	local success, result = pcall(function()
		return HttpService:JSONDecode(jsonString)
	end)
	return success and result or nil
end

FELOADLIBRARY.EncodeJSON = function(jsonTable: table)
	if type(jsonTable) ~= "table" then
		warn("LoadLibrary.EncodeJSON expects a table argument!")
		return "{}"
	end
	local success, result = pcall(function()
		return HttpService:JSONEncode(jsonTable)
	end)
	return success and result or "{}"
end







